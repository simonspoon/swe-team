#!/usr/bin/env bash
#
# limbodrain — drain the limbo task queue.
#
# Usage:
#   limbodrain            drain every unblocked non-done leaf task
#   limbodrain <task-id>  drain that task's subtree (descendants first, then root)
#
# Mechanism per iteration:
#   1. pick the next unblocked non-done leaf task
#   2. spawn a background swe-team:maestro agent to execute it
#   3. poll limbo until the task is done (or blocked / decomposed / timed out)
#   4. loop until nothing left to drain, then exit 0
#
# Env vars:
#   LIMBODRAIN_POLL_INTERVAL  seconds between limbo polls (default 5)
#   LIMBODRAIN_MAX_WAIT       max seconds to wait for one task (default 3000)
#
set -euo pipefail

POLL_INTERVAL="${LIMBODRAIN_POLL_INTERVAL:-5}"
MAX_WAIT="${LIMBODRAIN_MAX_WAIT:-3000}"

# --- repo root -------------------------------------------------------------
# limbo and the spawned agent must share a working directory so .limbo and
# CLAUDE.md auto-discovery resolve consistently.
if ! REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null); then
  echo "Error: limbodrain must be run from inside a git repository" >&2
  exit 1
fi
cd "$REPO_ROOT"

echo "Warning: limbodrain has no lock on limbo state — do not run two drains, or edit limbo by hand, concurrently." >&2

# --- interrupt handling ----------------------------------------------------
SESSION_ID=""
CURRENT_ID=""
on_interrupt() {
  if [ -n "$SESSION_ID" ]; then
    echo "Interrupted. Background agent session: $SESSION_ID — run: claude stop $SESSION_ID" >&2
  elif [ -n "$CURRENT_ID" ]; then
    echo "Interrupted. Warning: a background agent for task $CURRENT_ID may still be running (no session id captured)." >&2
  fi
  exit 130
}
trap on_interrupt INT TERM

# --- subtree id collection -------------------------------------------------
# Walk `limbo list --parent <id>` recursively. Prints root + all descendant ids,
# one per line. limbo tree has no positional id arg, so we build the set here.
subtree_ids() {
  local root="$1"
  ROOT="$root" python3 <<'PY'
import json, os, subprocess, sys

root = os.environ["ROOT"]

def children(task_id):
    try:
        out = subprocess.run(
            ["limbo", "list", "--parent", task_id],
            capture_output=True, text=True, check=True,
        ).stdout
        data = json.loads(out) if out.strip() else None
    except Exception as e:
        sys.stderr.write(f"warning: failed to list children of {task_id}: {e}\n")
        return []
    tasks = data or []
    ids = []
    for t in tasks:
        try:
            tid = t.get("id")
            if tid:
                ids.append(tid)
        except Exception:
            sys.stderr.write("warning: skipping malformed task record\n")
    return ids

seen = set()
stack = [root]
while stack:
    cur = stack.pop()
    if cur in seen:
        continue
    seen.add(cur)
    stack.extend(children(cur))

for tid in seen:
    print(tid)
PY
}

# --- child count -----------------------------------------------------------
# limbo show has NO 'children' key — count via a separate list call.
child_count() {
  local task_id="$1"
  TASK_ID="$task_id" python3 <<'PY'
import json, os, subprocess, sys

task_id = os.environ["TASK_ID"]
try:
    out = subprocess.run(
        ["limbo", "list", "--parent", task_id],
        capture_output=True, text=True, check=True,
    ).stdout
    data = json.loads(out) if out.strip() else None
except Exception as e:
    sys.stderr.write(f"warning: failed to count children of {task_id}: {e}\n")
    print(0)
else:
    print(len(data or []))
PY
}

# --- next task selection ---------------------------------------------------
# Prints the id of the first unblocked non-done leaf in scope, or nothing.
# A leaf = a task with no non-done child within scope.
# $1 (optional) = newline-separated set of in-scope ids; empty = full queue.
next_task() {
  local scope="${1:-}"
  SCOPE="$scope" python3 <<'PY'
import json, os, subprocess, sys

scope_raw = os.environ.get("SCOPE", "").strip()
scope = set(scope_raw.split()) if scope_raw else None

def run(args):
    return subprocess.run(
        ["limbo", *args], capture_output=True, text=True, check=True
    ).stdout

try:
    out = run(["list", "--unblocked"])
    data = json.loads(out) if out.strip() else None
except Exception as e:
    sys.stderr.write(f"warning: failed to list unblocked tasks: {e}\n")
    sys.exit(0)

tasks = data or []

# children cache keyed by parent id -> list of child task dicts
_cache = {}
def children(task_id):
    if task_id in _cache:
        return _cache[task_id]
    try:
        out = run(["list", "--parent", task_id])
        cdata = json.loads(out) if out.strip() else None
    except Exception as e:
        sys.stderr.write(f"warning: failed to list children of {task_id}: {e}\n")
        cdata = None
    result = []
    for c in (cdata or []):
        try:
            result.append(c)
        except Exception:
            sys.stderr.write("warning: skipping malformed task record\n")
    _cache[task_id] = result
    return result

def is_leaf(task_id):
    for c in children(task_id):
        cid = c.get("id")
        cstatus = c.get("status", "")
        if scope is not None and cid not in scope:
            continue  # out-of-scope children don't block the leaf decision
        if cstatus != "done":
            return False
    return True

for t in tasks:
    try:
        tid = t.get("id")
        status = t.get("status", "")
    except Exception:
        sys.stderr.write("warning: skipping malformed task record\n")
        continue
    if not tid or status == "done":
        continue
    if scope is not None and tid not in scope:
        continue
    if is_leaf(tid):
        print(tid)
        break
PY
}

# --- blocked / status probe ------------------------------------------------
# Prints one of: done | blocked | <other-status> ; second word = manualBlockReason.
task_state() {
  local task_id="$1"
  TASK_ID="$task_id" python3 <<'PY'
import json, os, subprocess, sys

task_id = os.environ["TASK_ID"]
try:
    out = subprocess.run(
        ["limbo", "show", task_id],
        capture_output=True, text=True, check=True,
    ).stdout
    data = json.loads(out) if out.strip() else None
except Exception as e:
    sys.stderr.write(f"warning: failed to show {task_id}: {e}\n")
    print("unknown")
    sys.exit(0)

task = data or {}
status = task.get("status", "")
reason = task.get("manualBlockReason") or ""
if reason:
    print("blocked", reason)
else:
    print(status or "unknown")
PY
}

# --- drain one task --------------------------------------------------------
# Returns 0 if the task reached done or was decomposed; 1 if blocked or timed out.
# Sets DECOMPOSED=1 when it returned 0 because the task gained children, so the
# main loop can distinguish a completed task from a decomposed (re-appearing) one.
DECOMPOSED=0
drain_one() {
  local id="$1"
  CURRENT_ID="$id"
  DECOMPOSED=0

  local initial_children
  initial_children=$(child_count "$id")

  echo "Draining $id ..." >&2

  local bg_output bg_status
  set +e
  bg_output=$(claude --dangerously-skip-permissions --plugin-dir ~/claudehub/swe-team --mcp-config "" --strict-mcp-config --agent swe-team:maestro --bg "Execute limbo task $id" 2>&1) # --mcp-config "" + --strict-mcp-config: verified accepted by claude CLI (exit 0); together they disable all MCP servers for this invocation.
  bg_status=$?
  set -e

  if [ "$bg_status" -ne 0 ]; then
    echo "Error: failed to spawn background agent for task $id (claude exited $bg_status)." >&2
    echo "$bg_output" >&2
    SESSION_ID=""
    CURRENT_ID=""
    exit 1
  fi

  # Best-effort session-id capture for the interrupt trap. The --bg output
  # format is unspecified; grab the first session-id-like token if present.
  SESSION_ID=$(printf '%s\n' "$bg_output" \
    | grep -oE '[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}' \
    | head -n1 || true)

  # Wall-clock timeout: a counter incremented by POLL_INTERVAL never advances
  # when POLL_INTERVAL=0, so derive elapsed time from the clock instead.
  local start_time
  start_time=$(date +%s)
  while true; do
    local state reason
    state=$(task_state "$id")
    reason="${state#* }"
    state="${state%% *}"

    if [ "$state" = "done" ]; then
      echo "Task $id is done." >&2
      SESSION_ID=""
      CURRENT_ID=""
      return 0
    fi

    if [ "$state" = "blocked" ]; then
      echo "Task $id is blocked: $reason" >&2
      SESSION_ID=""
      CURRENT_ID=""
      return 1
    fi

    local now_children
    now_children=$(child_count "$id")
    if [ "$now_children" -gt "$initial_children" ]; then
      echo "Task $id was decomposed into subtasks — re-entering drain loop." >&2
      SESSION_ID=""
      CURRENT_ID=""
      DECOMPOSED=1
      return 0
    fi

    local elapsed
    elapsed=$(( $(date +%s) - start_time ))
    if [ "$elapsed" -ge "$MAX_WAIT" ]; then
      echo "Timed out waiting for $id (${MAX_WAIT}s)." >&2
      SESSION_ID=""
      CURRENT_ID=""
      return 1
    fi

    sleep "$POLL_INTERVAL"
  done
}

# --- main ------------------------------------------------------------------
TASKID=""
if [ "$#" -gt 0 ]; then
  TASKID="$1"
  if ! limbo show "$TASKID" >/dev/null 2>&1; then
    echo "Error: task '$TASKID' not found in limbo" >&2
    exit 1
  fi
fi

last_id=""
while :; do
  # Recompute the subtree scope each iteration: a decomposed task adds new
  # descendants that must enter scope before the next leaf is selected.
  if [ -n "$TASKID" ]; then
    SCOPE=$(subtree_ids "$TASKID")
  else
    SCOPE=""
  fi

  id=$(next_task "$SCOPE")
  [ -n "$id" ] || break

  if [ "$id" = "$last_id" ]; then
    echo "Error: same task $id selected twice in a row — aborting to avoid an infinite loop" >&2
    exit 1
  fi
  last_id="$id"
  drain_one "$id" || exit 1

  # A decomposed parent legitimately re-appears as a candidate once its new
  # children are drained. Reset last_id so the same-id abort guard does not
  # trip on that legitimate re-selection.
  if [ "$DECOMPOSED" -eq 1 ]; then
    last_id=""
  fi
done

echo "Queue drained — nothing left to do." >&2
exit 0
