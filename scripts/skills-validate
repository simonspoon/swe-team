#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# ///
"""Validate swe-team plugin skills.

Usage:
  skills-validate              # validate all skills
  skills-validate <name>       # validate one skill
  skills-validate --changed    # validate only git-changed skills
"""
from __future__ import annotations

import argparse
import json
import re
import shutil
import subprocess
import sys
from dataclasses import dataclass, field
from enum import Enum
from pathlib import Path
from typing import Callable


# ---------------------------------------------------------------------------
# Data types
# ---------------------------------------------------------------------------

class Severity(Enum):
    PASS = "pass"
    WARN = "warn"
    FAIL = "fail"


@dataclass
class Finding:
    severity: Severity
    message: str
    context: str | None = None


@dataclass
class SkillInfo:
    name: str
    path: Path  # path to SKILL.md
    frontmatter: dict[str, str] = field(default_factory=dict)
    body: str = ""


# ---------------------------------------------------------------------------
# Checker registry
# ---------------------------------------------------------------------------

CheckerFn = Callable[[SkillInfo], list[Finding]]

_checkers: list[tuple[str, CheckerFn]] = []


def register_checker(name: str, fn: CheckerFn) -> None:
    """Register a checker function."""
    _checkers.append((name, fn))


def get_checkers() -> list[tuple[str, CheckerFn]]:
    """Return all registered checkers."""
    return list(_checkers)


# ---------------------------------------------------------------------------
# Frontmatter parsing (stdlib only — no pyyaml dep)
# ---------------------------------------------------------------------------

_FM_RE = re.compile(r"\A---\s*\n(.*?)\n---\s*\n", re.DOTALL)
_KV_RE = re.compile(r"^(\w[\w-]*):\s*(.+)", re.MULTILINE)


def parse_skill_file(path: Path) -> SkillInfo:
    """Parse a SKILL.md into SkillInfo with frontmatter dict and body."""
    text = path.read_text(encoding="utf-8")
    frontmatter: dict[str, str] = {}
    body = text

    m = _FM_RE.match(text)
    if m:
        raw_fm = m.group(1)
        # Handle simple key: value pairs and multi-line values (>)
        current_key = None
        lines = raw_fm.split("\n")
        for line in lines:
            kv = _KV_RE.match(line)
            if kv:
                current_key = kv.group(1)
                val = kv.group(2).strip()
                if val in (">", "|"):
                    frontmatter[current_key] = ""
                else:
                    frontmatter[current_key] = val.strip('"').strip("'")
            elif current_key and line.startswith("  "):
                # continuation of multi-line value
                prev = frontmatter.get(current_key, "")
                addition = line.strip()
                if prev:
                    frontmatter[current_key] = prev + " " + addition
                else:
                    frontmatter[current_key] = addition
        body = text[m.end():]

    name = frontmatter.get("name", path.parent.name)
    return SkillInfo(name=name, path=path, frontmatter=frontmatter, body=body)


# ---------------------------------------------------------------------------
# Checkers: frontmatter
# ---------------------------------------------------------------------------

_KEBAB_RE = re.compile(r"^[a-z][a-z0-9]*(-[a-z0-9]+)*$")


def check_frontmatter(skill: SkillInfo) -> list[Finding]:
    """Validate frontmatter presence and required fields."""
    findings: list[Finding] = []

    # 1. Frontmatter block must exist (empty dict means nothing was parsed)
    if not skill.frontmatter:
        findings.append(Finding(
            severity=Severity.FAIL,
            message="No frontmatter block found",
            context=str(skill.path),
        ))
        return findings  # no point checking fields

    # 2. 'name' field — required, non-empty
    name_val = skill.frontmatter.get("name", "").strip()
    if not name_val:
        findings.append(Finding(
            severity=Severity.FAIL,
            message="Missing or empty 'name' field in frontmatter",
            context=str(skill.path),
        ))
    elif not _KEBAB_RE.match(name_val):
        findings.append(Finding(
            severity=Severity.WARN,
            message=f"Name '{name_val}' is not kebab-case",
            context=str(skill.path),
        ))

    # 3. 'description' field — required, non-empty
    desc_val = skill.frontmatter.get("description", "").strip()
    if not desc_val:
        findings.append(Finding(
            severity=Severity.FAIL,
            message="Missing or empty 'description' field in frontmatter",
            context=str(skill.path),
        ))

    return findings


register_checker("frontmatter", check_frontmatter)


# ---------------------------------------------------------------------------
# Checkers: binary existence
# ---------------------------------------------------------------------------

# Tools the swe-team ecosystem may reference — warframe-themed + common CLIs.
# Only these are checked; generic commands (cd, ls, cat) are ignored.
KNOWN_BINARIES: set[str] = {
    "banshee", "dante", "helios", "ivara", "khora", "limbo", "loki",
    "mirage", "nova", "nyx", "qorvex", "simaris", "vauban", "vox",
    "wisp", "xaku",
    # common CLIs that skills may depend on
    "cargo", "docker", "gh", "pnpm", "terraform", "uv",
}

# Matches content inside inline backticks: `some command`
_INLINE_BACKTICK_RE = re.compile(r"`([^`]+)`")
# Matches content inside fenced code blocks: ```...```
_FENCED_BLOCK_RE = re.compile(r"```[^\n]*\n(.*?)```", re.DOTALL)


def _extract_referenced_binaries(body: str) -> set[str]:
    """Extract known binary names from backtick-wrapped content in a skill body."""
    candidates: set[str] = set()

    # Collect all text inside backticks and fenced blocks
    regions: list[str] = []
    for m in _FENCED_BLOCK_RE.finditer(body):
        regions.append(m.group(1))
    for m in _INLINE_BACKTICK_RE.finditer(body):
        regions.append(m.group(1))

    # Extract words and intersect with known set
    word_re = re.compile(r"[a-z][a-z0-9-]*")
    for region in regions:
        for token in word_re.findall(region):
            if token in KNOWN_BINARIES:
                candidates.add(token)

    return candidates


def check_binaries(skill: SkillInfo) -> list[Finding]:
    """Check that CLI tools referenced in the skill body exist on PATH."""
    findings: list[Finding] = []

    referenced = _extract_referenced_binaries(skill.body)
    for binary in sorted(referenced):
        if shutil.which(binary) is None:
            findings.append(Finding(
                severity=Severity.FAIL,
                message=f"Binary not found on PATH: {binary}",
                context=str(skill.path),
            ))

    return findings


register_checker("binaries", check_binaries)


# ---------------------------------------------------------------------------
# Checkers: file-path resolution
# ---------------------------------------------------------------------------

# Cache repo root across checker invocations
_repo_root: Path | None = None


def _get_repo_root() -> Path:
    """Return the git repo root, cached after first call."""
    global _repo_root
    if _repo_root is None:
        result = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True,
        )
        _repo_root = Path(result.stdout.strip()) if result.returncode == 0 else Path(".")
    return _repo_root


# Skill-local resource directories whose file references should be validated.
# Paths starting with these prefixes (with a file extension) are real references
# to files that the skill depends on. Bare directory references (no extension)
# are structural and may not exist yet — skip those.
_SKILL_RESOURCE_PREFIXES = ("reference/", "knowledge/", "templates/")

# Matches a relative path token inside backtick content
_RELATIVE_PATH_RE = re.compile(r"[a-zA-Z0-9_.][a-zA-Z0-9_./\-]*")

# Disqualifying patterns (template placeholders, env vars, globs)
_PATH_SKIP_RE = re.compile(
    r"<[a-zA-Z_-]+>"      # angle-bracket placeholders: <name>
    r"|\{[a-zA-Z_]"        # brace placeholders: {var}
    r"|\$\{?\w"            # env vars: $VAR, ${VAR}
    r"|[*?]"               # glob wildcards
)


def _extract_skill_resource_paths(body: str) -> list[str]:
    """Extract skill-local resource paths from inline backtick spans.

    Only paths starting with known resource prefixes (reference/, knowledge/,
    templates/) that have a file extension are checked. This avoids false
    positives on example paths, CLI commands, and documentation references
    to other projects.
    """
    paths: list[str] = []

    for m in _INLINE_BACKTICK_RE.finditer(body):
        content = m.group(1).strip()

        # Must contain / to be path-shaped
        if "/" not in content:
            continue

        # Extract the path-shaped portion
        pm = _RELATIVE_PATH_RE.search(content)
        if not pm:
            continue

        candidate = pm.group(0).rstrip(".,;:)")

        # Must start with a known resource prefix
        if not any(candidate.startswith(p) for p in _SKILL_RESOURCE_PREFIXES):
            continue

        # Must have a file extension (skip bare directory references)
        if "." not in candidate.split("/")[-1]:
            continue

        # Skip template placeholders and globs
        if _PATH_SKIP_RE.search(candidate):
            continue

        paths.append(candidate)

    return list(dict.fromkeys(paths))  # dedupe, preserve order


def _resolve_path(path_str: str, skill_dir: Path) -> bool:
    """Check whether a relative path resolves from skill dir or repo root."""
    p = Path(path_str)
    if (skill_dir / p).exists():
        return True
    if (_get_repo_root() / p).exists():
        return True
    return False


def check_paths(skill: SkillInfo) -> list[Finding]:
    """Check that file paths referenced in the skill body actually exist."""
    findings: list[Finding] = []
    skill_dir = skill.path.parent

    referenced = _extract_skill_resource_paths(skill.body)
    for path_str in referenced:
        if not _resolve_path(path_str, skill_dir):
            findings.append(Finding(
                severity=Severity.FAIL,
                message=f"Referenced path not found: {path_str}",
                context=str(skill.path),
            ))

    return findings


register_checker("paths", check_paths)


# ---------------------------------------------------------------------------
# Checkers: trigger string-match (nyx fixture sourcing)
# ---------------------------------------------------------------------------

_FIXTURES_FILE = Path(__file__).resolve().parent / "skills-validate-fixtures.json"
_refresh_fixtures: bool = False


def _load_fixtures() -> dict[str, str]:
    """Load or build the nyx fixture cache.

    Returns a dict mapping skill name → canonical user prompt snippet.
    When _refresh_fixtures is True (or cache doesn't exist), queries nyx
    for each skill discovered so far and writes the cache.
    """
    if not _refresh_fixtures and _FIXTURES_FILE.exists():
        try:
            return json.loads(_FIXTURES_FILE.read_text(encoding="utf-8"))
        except (json.JSONDecodeError, OSError):
            pass  # corrupt cache — rebuild

    return {}  # built lazily per-skill via _get_fixture


def _nyx_search(query: str) -> str | None:
    """Run a single nyx search and return the most recent user prompt snippet."""
    try:
        result = subprocess.run(
            ["nyx", "search", query, "--json"],
            capture_output=True, text=True, timeout=15,
        )
        if result.returncode != 0 or not result.stdout.strip():
            return None
        hits = json.loads(result.stdout)
        user_hits = [h for h in hits if h.get("role") == "user" and h.get("snippet")]
        if not user_hits:
            return None
        user_hits.sort(key=lambda h: h.get("timestamp", ""), reverse=True)
        return user_hits[0]["snippet"]
    except (subprocess.TimeoutExpired, json.JSONDecodeError, OSError, KeyError):
        return None


def _query_nyx(skill_name: str) -> str | None:
    """Query nyx for the most recent user prompt mentioning a skill.

    Tries the full skill name first, then falls back to the longest
    dash-separated component (e.g. 'khora-test-web' → 'khora').
    """
    if shutil.which("nyx") is None:
        return None

    # Try full name first
    result = _nyx_search(skill_name)
    if result:
        return result

    # Fallback: longest component of the skill name (most distinctive)
    parts = skill_name.split("-")
    if len(parts) > 1:
        longest = max(parts, key=len)
        if len(longest) > 2:
            return _nyx_search(longest)

    return None


def _get_fixture(skill_name: str, cache: dict[str, str]) -> str | None:
    """Get a fixture for a skill, querying nyx if refreshing or not cached."""
    if not _refresh_fixtures and skill_name in cache:
        return cache[skill_name]
    if _refresh_fixtures or skill_name not in cache:
        prompt = _query_nyx(skill_name)
        if prompt is not None:
            cache[skill_name] = prompt
        return prompt
    return cache.get(skill_name)


def _save_fixtures(cache: dict[str, str]) -> None:
    """Write the fixture cache to disk."""
    try:
        _FIXTURES_FILE.write_text(
            json.dumps(cache, indent=2, sort_keys=True) + "\n",
            encoding="utf-8",
        )
    except OSError:
        pass  # non-fatal — cache is convenience, not critical


# Phrases stripped from the description before extracting trigger keywords
_TRIGGER_STRIP_PHRASES = [
    "use when the user",
    "use when user",
    "use when",
    "user mentions",
    "user asks to",
    "user asks for",
    "user wants to",
    "triggers on",
    "triggers:",
    "trigger when",
    "trigger:",
    "also use when",
    "also use for",
]

_TRIGGER_STOP_WORDS = frozenset({
    "a", "an", "the", "and", "or", "of", "for", "in", "on", "to", "is",
    "are", "with", "by", "from", "at", "as", "any", "that", "this",
    "e.g.", "eg", "etc", "when", "also", "not", "do", "use",
})


def _extract_trigger_keywords(description: str, skill_name: str) -> set[str]:
    """Extract trigger keywords from a skill's description field.

    Heuristic: find text after trigger phrases ('Use when', 'Triggers on', etc.),
    split on commas, strip noise words, lowercase, dedupe. Also includes the
    skill name and its dash-separated parts.
    """
    keywords: set[str] = set()

    # Add skill name and its parts
    keywords.add(skill_name.lower())
    for part in skill_name.lower().split("-"):
        if part and part not in _TRIGGER_STOP_WORDS and len(part) > 2:
            keywords.add(part)

    desc_lower = description.lower()

    # Try to find trigger-phrase regions and extract keywords from them
    for phrase in _TRIGGER_STRIP_PHRASES:
        idx = desc_lower.find(phrase)
        if idx == -1:
            continue
        # Text after the trigger phrase
        after = desc_lower[idx + len(phrase):]
        # Split on commas and periods (sentence boundaries)
        segments = re.split(r"[,.]", after)
        for seg in segments:
            seg = seg.strip()
            if not seg:
                continue
            # Each segment is a trigger like "testing web apps" or "browser testing"
            words = seg.split()
            # Add multi-word phrase (joined) and individual meaningful words
            phrase_clean = " ".join(w for w in words if w not in _TRIGGER_STOP_WORDS)
            if phrase_clean and len(phrase_clean) > 2:
                keywords.add(phrase_clean)
            for w in words:
                if w not in _TRIGGER_STOP_WORDS and len(w) > 2:
                    keywords.add(w)

    return keywords


# Module-level cache shared across checker invocations
_fixture_cache: dict[str, str] | None = None


def check_triggers(skill: SkillInfo) -> list[Finding]:
    """Check that trigger keywords from the description appear in real user prompts."""
    global _fixture_cache
    findings: list[Finding] = []

    description = skill.frontmatter.get("description", "").strip()
    if not description:
        return findings  # frontmatter checker already flags this

    # Lazy-load fixture cache
    if _fixture_cache is None:
        _fixture_cache = _load_fixtures()

    keywords = _extract_trigger_keywords(description, skill.name)
    if not keywords:
        findings.append(Finding(
            severity=Severity.WARN,
            message="No trigger keywords extracted from description",
            context=str(skill.path),
        ))
        return findings

    prompt = _get_fixture(skill.name, _fixture_cache)
    if prompt is None:
        findings.append(Finding(
            severity=Severity.WARN,
            message="No nyx fixture — no conversation history found for this skill",
            context=str(skill.path),
        ))
        return findings

    prompt_lower = prompt.lower()
    matched = any(kw in prompt_lower for kw in keywords)
    if not matched:
        findings.append(Finding(
            severity=Severity.WARN,
            message="Trigger keyword mismatch — no extracted keywords found in canonical prompt",
            context=f"keywords: {sorted(keywords)[:10]}",
        ))

    return findings


register_checker("triggers", check_triggers)


# ---------------------------------------------------------------------------
# Skill discovery
# ---------------------------------------------------------------------------

def discover_skills(skills_dir: Path) -> list[SkillInfo]:
    """Walk skills/ and return parsed SkillInfo for each SKILL.md."""
    results = []
    for skill_md in sorted(skills_dir.glob("*/SKILL.md")):
        results.append(parse_skill_file(skill_md))
    return results


def filter_by_name(skills: list[SkillInfo], name: str) -> list[SkillInfo]:
    """Filter to a single skill by name."""
    matches = [s for s in skills if s.name == name]
    if not matches:
        # try directory name fallback
        matches = [s for s in skills if s.path.parent.name == name]
    return matches


def filter_by_changed(skills: list[SkillInfo], repo_root: Path) -> list[SkillInfo]:
    """Filter to skills with files changed in git (staged + unstaged vs HEAD)."""
    try:
        result = subprocess.run(
            ["git", "diff", "--name-only", "HEAD"],
            capture_output=True, text=True, cwd=repo_root,
        )
        changed = set(result.stdout.strip().splitlines())
        # Also check untracked
        result2 = subprocess.run(
            ["git", "ls-files", "--others", "--exclude-standard"],
            capture_output=True, text=True, cwd=repo_root,
        )
        changed.update(result2.stdout.strip().splitlines())
    except FileNotFoundError:
        print("error: git not found", file=sys.stderr)
        sys.exit(2)

    # A skill is "changed" if any file under its directory appears in the diff
    changed_skills = []
    for skill in skills:
        skill_rel = skill.path.parent.relative_to(repo_root)
        if any(c.startswith(str(skill_rel) + "/") or c == str(skill_rel) for c in changed):
            changed_skills.append(skill)
    return changed_skills


# ---------------------------------------------------------------------------
# Aggregator + output
# ---------------------------------------------------------------------------

def run_checkers(skills: list[SkillInfo]) -> bool:
    """Run all checkers on each skill. Print results. Return True if all pass."""
    checkers = get_checkers()
    any_fail = False

    for skill in skills:
        findings: list[Finding] = []
        for _checker_name, checker_fn in checkers:
            findings.extend(checker_fn(skill))

        has_fail = any(f.severity == Severity.FAIL for f in findings)
        has_warn = any(f.severity == Severity.WARN for f in findings)

        if has_fail:
            any_fail = True
            print(f"✗ {skill.name}")
        elif has_warn:
            print(f"⚠ {skill.name}")
        else:
            print(f"✓ {skill.name}")

        # Print sub-findings (warn and fail only)
        for f in findings:
            if f.severity == Severity.FAIL:
                print(f"  ✗ {f.message}")
            elif f.severity == Severity.WARN:
                print(f"  ⚠ {f.message}")

    return not any_fail


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

def find_repo_root() -> Path:
    """Find the repo root (parent of scripts/)."""
    return Path(__file__).resolve().parent.parent


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="skills-validate",
        description="Validate swe-team plugin skills.",
    )
    parser.add_argument(
        "name",
        nargs="?",
        help="Skill name to validate (omit for all)",
    )
    parser.add_argument(
        "--changed",
        action="store_true",
        help="Only validate skills with git-changed files",
    )
    parser.add_argument(
        "--refresh-fixtures",
        action="store_true",
        help="Re-fetch trigger fixtures from nyx (rewrites cache)",
    )
    args = parser.parse_args()

    if args.name and args.changed:
        parser.error("cannot combine skill name with --changed")

    # Set module-level refresh flag for the trigger checker
    global _refresh_fixtures
    _refresh_fixtures = args.refresh_fixtures

    repo_root = find_repo_root()
    skills_dir = repo_root / "skills"

    if not skills_dir.is_dir():
        print(f"error: skills directory not found: {skills_dir}", file=sys.stderr)
        sys.exit(2)

    all_skills = discover_skills(skills_dir)

    if args.name:
        skills = filter_by_name(all_skills, args.name)
        if not skills:
            print(f"error: skill not found: {args.name}", file=sys.stderr)
            sys.exit(2)
    elif args.changed:
        skills = filter_by_changed(all_skills, repo_root)
        if not skills:
            # nothing changed — nothing to validate
            sys.exit(0)
    else:
        skills = all_skills

    all_pass = run_checkers(skills)

    # Persist fixture cache if it was populated
    if _fixture_cache is not None:
        _save_fixtures(_fixture_cache)

    sys.exit(0 if all_pass else 1)


if __name__ == "__main__":
    main()
